rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    // Sparks só podem ser CRIADAS com o valor inicial padrão (50) e nunca
    // aumentadas pelo cliente em um update — apenas reduzidas (gasto).
    // Qualquer crédito real (compra confirmada) deve vir de uma Cloud
    // Function com Admin SDK, que ignora estas regras.
    function startingSparksOk() {
      return !request.resource.data.keys().hasAny(['sparks']) ||
             request.resource.data.sparks == 50;
    }
    function sparksNotIncreased() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['sparks']) ||
             (request.resource.data.sparks >= 0 &&
              request.resource.data.sparks <= resource.data.sparks);
    }

    // ─── Users ────────────────────────────────────────────
    // Leitura: apenas campos públicos (não e-mail, não fcmToken)
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId)
        && startingSparksOk()
        // Impede que o cliente já se crie verificado
        && (!request.resource.data.keys().hasAny(['verified']) ||
             request.resource.data.verified == false);
      allow update: if isOwner(userId)
        // Impede saldo negativo OU aumento de SPARKS pelo cliente
        && sparksNotIncreased()
        // Impede que o cliente se auto-verifique
        && (!request.resource.data.keys().hasAll(['verified']) ||
             request.resource.data.verified == resource.data.verified);
      allow delete: if false;
    }

    // ─── Matches ──────────────────────────────────────────
    match /matches/{matchId} {
      allow read: if isAuth() &&
        resource.data.users.hasAny([request.auth.uid]);
      allow create: if isAuth() &&
        request.resource.data.users.hasAny([request.auth.uid]);
      allow update: if isAuth() &&
        resource.data.users.hasAny([request.auth.uid]);
      allow delete: if false;
    }

    // ─── Conversations ────────────────────────────────────
    match /conversations/{convId} {
      allow read: if isAuth() &&
        resource.data.participants.hasAny([request.auth.uid]);
      allow create: if isAuth() &&
        request.resource.data.participants.hasAny([request.auth.uid]);
      allow update: if isAuth() &&
        resource.data.participants.hasAny([request.auth.uid]);
      allow delete: if false;

      match /messages/{msgId} {
        allow read, write: if isAuth() &&
          get(/databases/$(database)/documents/conversations/$(convId))
            .data.participants.hasAny([request.auth.uid]);
      }
    }

    // ─── Posts ────────────────────────────────────────────
    match /posts/{postId} {
      allow read:   if isAuth();
      allow create: if isAuth() &&
        request.resource.data.authorId == request.auth.uid;
      allow update: if isAuth() && (
        // Autor pode editar qualquer campo
        resource.data.authorId == request.auth.uid ||
        // Outros usuários só podem atualizar likes e likedBy (curtir/descurtir)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy'])
      );
      allow delete: if isAuth() &&
        resource.data.authorId == request.auth.uid;
    }

    // ─── Transactions ────────────────────────────────────
    match /transactions/{txId} {
      allow read: if isAuth() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuth() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ─── Gallery ─────────────────────────────────────────
    // Leitura: dono sempre lê; outros só lêem fotos desbloqueadas
    match /gallery/{userId}/photos/{photoId} {
      allow read: if isAuth() && (
        request.auth.uid == userId ||
        !resource.data.isLocked ||
        resource.data.unlockedBy.hasAny([request.auth.uid])
      );
      allow create: if isOwner(userId)
        && request.resource.data.size() <= 10;
      allow update: if isAuth() && (
        // Dono pode alterar qualquer campo
        request.auth.uid == userId ||
        // Outros só podem adicionar próprio UID em unlockedBy
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['unlockedBy']) &&
         request.resource.data.unlockedBy.hasAll(resource.data.unlockedBy) &&
         request.resource.data.unlockedBy.hasAny([request.auth.uid]))
      );
      allow delete: if isOwner(userId);
    }

    // ─── Swipes ───────────────────────────────────────────
    // Apenas o dono escreve; dono ou alvo lê (necessário para mutual like)
    match /swipes/{userId}/actions/{targetId} {
      allow write: if isOwner(userId);
      allow read:  if isAuth() &&
        (request.auth.uid == userId || request.auth.uid == targetId);
    }

    // ─── Blocks ───────────────────────────────────────────
    match /blocks/{userId}/blocked/{targetId} {
      allow read, write, delete: if isOwner(userId);
    }

    // ─── Reports ──────────────────────────────────────────
    match /reports/{reportId} {
      allow create: if isAuth() &&
        request.resource.data.reportedBy == request.auth.uid;
      allow read:   if false; // Somente admin (Cloud Functions)
      allow update, delete: if false;
    }

    // ─── Stripe Events (idempotência do webhook) ──────────
    // Escrito apenas pela Cloud Function `stripeWebhook` via Admin SDK,
    // que ignora estas regras. Nenhum cliente deve ler ou escrever aqui.
    match /stripeEvents/{eventId} {
      allow read, write: if false;
    }

    // ─── Stories ─────────────────────────────────────────
    match /stories/{storyId} {
      allow read: if isAuth();
      allow create: if isAuth() &&
        request.resource.data.uid == request.auth.uid;
      allow update: if isAuth() && (
        // Dono pode deletar/editar
        resource.data.uid == request.auth.uid ||
        // Outros só podem adicionar próprio UID em views ou reactions
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['views', 'reactions'])
      );
      allow delete: if isAuth() && resource.data.uid == request.auth.uid;
    }

  }
}
